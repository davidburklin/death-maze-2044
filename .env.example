# Convex
NUXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-name

# Google OAuth (configure at https://console.cloud.google.com/)
AUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session
AUTH_SESSION_SECRET=replace-with-a-random-32-char-secret
AUTH_APP_URL=http://localhost:3000
